<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_task_form_github" model="ir.ui.view">
        <field name="name">project.task.form.github</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="GitHub PR" name="github_pr">
                    <group>
                        <group string="Pull Request Info">
                            <field name="github_pr_url" widget="url" />
                            <field name="github_pr_number" />
                            <field name="github_pr_state"
                                widget="badge"
                                decoration-success="github_pr_state == 'merged'"
                                decoration-info="github_pr_state == 'open'"
                                decoration-muted="github_pr_state == 'closed'"
                            />
                        </group>
                    </group>
                    <group string="PR Description">
                        <field name="github_pr_description" nolabel="1" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
