<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_github" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.kmitl.project.github</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50" />
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div
                    class="app_settings_block"
                    data-string="GitHub Integration"
                    string="GitHub Integration"
                    data-key="kmitl_project_github"
                >
                    <h2>GitHub OAuth App</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">OAuth App Setup</span>
                                <div class="text-muted">
                                    สร้าง OAuth App ที่
                                    <a href="https://github.com/settings/developers" target="_blank">
                                        github.com/settings/developers
                                    </a>
                                    แล้วตั้ง Authorization callback URL เป็น
                                    <code>[your-odoo-url]/github/oauth/callback</code>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="github_client_id" string="Client ID"/>
                                <field name="github_client_id"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="github_client_secret" string="Client Secret"/>
                                <field name="github_client_secret" password="True"/>
                            </div>
                        </div>
                    </div>
                    <h2>GitHub Webhook</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Webhook URL</span>
                                <div class="text-muted">
                                    ตั้งค่า Payload URL นี้ใน GitHub Repo Settings → Webhooks
                                    <br />
                                    <code>/github/webhook</code>
                                    (Content type: <code>application/json</code>, Events: Pull requests)
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="github_webhook_secret" string="Webhook Secret" />
                                <div class="text-muted">
                                    ใส่ค่าเดียวกับ Secret ที่ตั้งใน GitHub Webhook
                                </div>
                                <field name="github_webhook_secret" password="True" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <label for="github_task_prefix" string="Task Reference Prefix" />
                                <div class="text-muted">
                                    Prefix ที่ใช้ใน PR description เช่น
                                    <code>task</code>
                                    จะ match กับ
                                    <code>task-211</code>
                                </div>
                                <field name="github_task_prefix" />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
