<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_github" model="ir.ui.view">
        <field name="name">project.project.form.github</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//page[last()]" position="after">
                <page string="GitHub" name="github">
                    <group>
                        <group string="Webhook Settings">
                            <field name="github_task_prefix"
                                   placeholder="e.g. ok, task, fix"/>
                        </group>
                    </group>
                    <div class="d-flex align-items-center mb-3">
                        <h3 class="me-3 mb-0">Tracked Repositories</h3>
                        <button name="action_sync_and_link_repos"
                                type="object"
                                string="Sync &amp; Link Repos"
                                class="btn btn-secondary btn-sm"
                                icon="fa-github"/>
                    </div>
                    <field name="github_repository_ids" nolabel="1">
                        <tree string="Tracked Repositories" create="false">
                            <field name="full_name"/>
                            <field name="html_url" widget="url"/>
                            <field name="default_branch"/>
                            <field name="private" widget="boolean_toggle"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
