<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── List View ──────────────────────────────────────────────────────── -->
    <record id="view_github_repository_list" model="ir.ui.view">
        <field name="name">github.repository.list</field>
        <field name="model">github.repository</field>
        <field name="arch" type="xml">
            <tree string="GitHub Repositories">
                <field name="name" />
                <field name="full_name" />
                <field name="description" optional="show" />
                <field name="private" widget="boolean_toggle" optional="show" />
                <field name="default_branch" optional="show" />
                <field name="project_id" optional="show" />
                <field name="updated_at" optional="show" />
                <button
                    name="action_open_on_github"
                    type="object"
                    string="Open on GitHub"
                    icon="fa-external-link"
                    class="btn-sm"
                />
            </tree>
        </field>
    </record>

    <!-- ── Form View ─────────────────────────────────────────────────────── -->
    <record id="view_github_repository_form" model="ir.ui.view">
        <field name="name">github.repository.form</field>
        <field name="model">github.repository</field>
        <field name="arch" type="xml">
            <form string="GitHub Repository">
                <header>
                    <button
                        name="action_push_description_to_github"
                        type="object"
                        string="Push Description to GitHub"
                        class="btn-primary"
                        help="Updates the description on GitHub via the API (requires repo admin access)"
                    />
                    <button
                        name="action_sync_this_repo"
                        type="object"
                        string="Refresh from GitHub"
                        class="btn-secondary"
                    />
                    <button
                        name="action_open_on_github"
                        type="object"
                        string="Open on GitHub"
                        class="btn-secondary"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="full_name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group string="Repository Info">
                            <field name="name" readonly="1" />
                            <field name="private" readonly="1" />
                            <field name="default_branch" readonly="1" />
                            <field name="html_url" widget="url" readonly="1" />
                            <field name="updated_at" readonly="1" />
                        </group>
                        <group string="Odoo Links">
                            <field name="user_id" readonly="1" />
                            <field name="project_id" />
                            <field
                                name="github_id"
                                readonly="1"
                                groups="base.group_system"
                            />
                        </group>
                    </group>
                    <field
                        name="description"
                        placeholder="Repository description (editable — click 'Push Description to GitHub' to sync)"
                    />
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────────── -->
    <record id="view_github_repository_search" model="ir.ui.view">
        <field name="name">github.repository.search</field>
        <field name="model">github.repository</field>
        <field name="arch" type="xml">
            <search string="GitHub Repositories">
                <field name="name" string="Name" />
                <field name="full_name" string="Full Name" />
                <field name="project_id" />
                <filter
                    name="private"
                    string="Private"
                    domain="[('private', '=', True)]"
                />
                <filter
                    name="public"
                    string="Public"
                    domain="[('private', '=', False)]"
                />
                <filter
                    name="linked_to_project"
                    string="Linked to Project"
                    domain="[('project_id', '!=', False)]"
                />
                <group expand="0" string="Group By">
                    <filter
                        name="group_by_project"
                        string="Project"
                        context="{'group_by': 'project_id'}"
                    />
                    <filter
                        name="group_by_private"
                        string="Visibility"
                        context="{'group_by': 'private'}"
                    />
                </group>
            </search>
        </field>
    </record>
</odoo>
